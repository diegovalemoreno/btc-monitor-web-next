# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — NUNCA expor no client
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (gerar string aleatória segura)
CRON_SECRET=

# Telegram Bot (etapa 5)
TELEGRAM_BOT_TOKEN=

# Resend (etapa 5)
RESEND_API_KEY=
ALERT_EMAIL_FROM=

# Coinglass (liquidação heatmap)
COINGLASS_API_KEY=

# Glassnode — STH/LTH Realized Price chart
# Criar conta gratuita em https://studio.glassnode.com → Account → API Keys
# ⚠️  Métricas STH/LTH exigem plano Advanced (~$129/mês). Plano free não inclui.
GLASSNODE_API_KEY=
